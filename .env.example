# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/dz_store?schema=public"

# Auth (generate with: openssl rand -base64 32)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
NEXTAUTH_SECRET="your-nextauth-secret-change-this"
NEXTAUTH_URL="http://localhost:3000"

# Yalidine API Credentials
YALIDINE_API_ID="your-yalidine-api-id"
YALIDINE_API_TOKEN="your-yalidine-api-token"
YALIDINE_SENDER_WILAYA_ID="16"       # Default: Algiers (16)
YALIDINE_SENDER_NAME="متجر الجزائر"
YALIDINE_SENDER_PHONE="0555000000"
YALIDINE_SENDER_ADDRESS="الجزائر العاصمة"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="ar"
NODE_ENV="development"
